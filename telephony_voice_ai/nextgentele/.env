# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_PATH=./data/nextgentele.db

# AI Services
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4

# Twilio Configuration (for PSTN connectivity)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# AWS Configuration (for cloud services)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# SIP Configuration
SIP_DOMAIN=your_sip_domain.com
SIP_USERNAME=your_sip_username
SIP_PASSWORD=your_sip_password

# WebRTC Configuration
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVERS=turn:your_turn_server.com:3478

# Compliance & Regulation
CALL_RECORDING_ENABLED=true
GDPR_COMPLIANCE=true
HIPAA_COMPLIANCE=false
CALL_RETENTION_DAYS=30