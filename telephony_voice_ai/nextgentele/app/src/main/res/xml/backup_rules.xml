<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude sensitive data from backup -->
    <exclude domain="sharedpref" path="call_logs.xml"/>
    <exclude domain="sharedpref" path="ai_models.xml"/>
    <exclude domain="database" path="call_recordings.db"/>
    <exclude domain="file" path="audio_cache/"/>
    
    <!-- Include user preferences -->
    <include domain="sharedpref" path="user_preferences.xml"/>
    <include domain="sharedpref" path="ai_settings.xml"/>
</full-backup-content>